# Copy to .env and fill in values
# NEVER commit the .env file

# Anthropic (Required)
ANTHROPIC_API_KEY=sk-ant-...

# SEC API (Optional - leave blank for free EDGAR access)
SEC_API_KEY=

# Database
DATABASE_URL=sqlite:///./db/aequity.db

# Rate Limiting
SEC_REQUESTS_PER_SECOND=10
LLM_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
