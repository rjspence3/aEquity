# aEquity environment variables
# Copy to .env and fill in real values

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
SEC_USER_AGENT_EMAIL=your-email@example.com
DATABASE_URL=sqlite:///./db/aequity.db
LOG_LEVEL=INFO

# When set, gates the Analyze tab behind a simple password prompt.
# Prevents unbounded API spend on the public Railway deployment.
# Set via Railway Variables → Variables. Leave empty to disable the gate.
ANALYZE_ACCESS_TOKEN=
